# Build stage
FROM golang:1.22-alpine AS builder
RUN apk --no-cache add git
WORKDIR /app

COPY go.mod ./
COPY go.sum* ./
RUN go mod tidy && go mod download && go mod verify

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /llmproxy-worker ./cmd/worker/

# Run stage
FROM alpine:3.19
RUN apk --no-cache add ca-certificates
WORKDIR /app

COPY --from=builder /llmproxy-worker .

EXPOSE 9001
CMD ["./llmproxy-worker"]