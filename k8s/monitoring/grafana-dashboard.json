{
  "dashboard": {
    "title": "LLMProxy Dashboard",
    "uid": "llmproxy",
    "panels": [
      {
        "title": "Request Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(llmproxy_requests_total[1m])",
            "legendFormat": "{{method}} {{path}} {{status}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "title": "Request Latency (p50, p95, p99)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(llmproxy_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(llmproxy_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(llmproxy_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "title": "Cache Hit Rate %",
        "type": "gauge",
        "targets": [
          {
            "expr": "llmproxy_cache_hits_total / (llmproxy_cache_hits_total + llmproxy_cache_misses_total) * 100",
            "legendFormat": "Hit Rate %"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 }
      },
      {
        "title": "Rate Limited Requests",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(llmproxy_rate_limited_total[1m])",
            "legendFormat": "{{api_key}}"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 }
      },
      {
        "title": "Auth Rejections",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(llmproxy_auth_rejected_total[1m])",
            "legendFormat": "{{reason}}"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 }
      },
      {
        "title": "Backend Latency",
        "type": "heatmap",
        "targets": [
          {
            "expr": "rate(llmproxy_backend_latency_seconds_bucket[5m])",
            "legendFormat": "{{backend}}"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 }
      },
      {
        "title": "Estimated Cost ($)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(llmproxy_estimated_cost_dollars)",
            "legendFormat": "Total Cost"
          }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 }
      },
      {
        "title": "Active Connections",
        "type": "gauge",
        "targets": [
          {
            "expr": "llmproxy_active_connections",
            "legendFormat": "Active"
          }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 }
      },
      {
        "title": "Worker Health",
        "type": "stat",
        "targets": [
          {
            "expr": "llmproxy_worker_health",
            "legendFormat": "{{worker}}"
          }
        ],
        "gridPos": { "h": 4, "w": 12, "x": 12, "y": 16 }
      },
      {
        "title": "Token Usage per Key",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(llmproxy_tokens_used_total[5m])",
            "legendFormat": "{{api_key}} - {{type}}"
          }
        ],
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 }
      }
    ],
    "time": { "from": "now-1h", "to": "now" },
    "refresh": "5s"
  }
}